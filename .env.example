# Persistence layer. STORAGE_DRIVER = "local" (dev, writes ./data) or "github" (prod).
STORAGE_DRIVER=local

# --- GitHub JSON persistence (only needed when STORAGE_DRIVER=github) ---
# Fine-grained PAT with Contents: Read & Write on the data repo.
GITHUB_TOKEN=
# owner/repo that stores the JSON data files (can be this same repo or a private data repo)
GITHUB_REPO=your-user/usdt-data
GITHUB_BRANCH=main
# folder inside the repo where JSON files live
GITHUB_DATA_DIR=data

# --- Auth ---
# Comma list of "user:password:role" (role = admin | operador)
APP_USERS=admin:changeme:admin,operador:changeme:operador
# Secret used to sign the session cookie
AUTH_SECRET=please-change-this-long-random-string
